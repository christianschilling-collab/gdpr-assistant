# Gemini API Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Web SDK — use project team-cc-gdpr (same as AI Enablement dashboard)
# Console: https://console.firebase.google.com/project/team-cc-gdpr
# Project settings > Your apps > Web app — paste all config values as shown there
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=team-cc-gdpr
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: one-line JSON from Firebase → Project settings → Service accounts → Generate key.
# Enables: npm run init-data (seeds categories / requester types without browser login).
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"team-cc-gdpr",...}
